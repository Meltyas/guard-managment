<form class="guard-modal-form">
  <input type="hidden" name="organizationId" value="{{organizationId}}" />

  <div class="guard-modal-row">
    <label><i class="fas fa-tag"></i> Nombre</label>
    <input
      type="text"
      name="name"
      value="{{name}}"
      placeholder="Ej: Guía de los Vientos"
      required
    />
  </div>

  <div class="guard-modal-row">
    <label><i class="fas fa-heart"></i> Nivel de Reputación</label>
    <select name="level" required>
      {{#each reputationLevels}}
        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="guard-modal-row">
    <label><i class="fas fa-align-left"></i> Descripción</label>
    <textarea name="description" placeholder="Descripción opcional...">{{description}}</textarea>
  </div>

  <div class="guard-modal-row">
    <label><i class="fas fa-image"></i> Imagen</label>
    <div class="file-picker-wrapper">
      <input
        type="text"
        id="reputation-image"
        name="image"
        value="{{image}}"
        placeholder="Ruta de la imagen (opcional)"
      />
      <button
        type="button"
        class="file-picker-btn"
        data-target="reputation-image"
        title="Seleccionar imagen"
      >
        <i class="fas fa-folder-open"></i>
      </button>
    </div>
  </div>
</form>
