<div class='officer-warehouse-dialog' data-civil-tab='{{isCivilTab}}'>
  {{#if isGM}}
  <div class='content-header'>
    <h3>
      {{#if isCivilTab}}
      <i class='fas fa-user-friends'></i>
      Civiles
      {{else}}
      <i class='fas fa-user-shield'></i>
      Oficiales
      {{/if}}
    </h3>
    <div class='content-header-actions'>
      <button type='button' class='add-officer-btn' data-civil='{{isCivilTab}}'>
        <i class='fas fa-plus'></i>
        {{#if isCivilTab}}Nuevo Civil{{else}}Nuevo Oficial{{/if}}
      </button>
      {{#unless isCivilTab}}
      <button type='button' class='warehouse-export-btn' data-section='officers' data-section-label='oficiales' title='Exportar oficiales a JSON'>
        <i class='fas fa-file-export'></i>
        Exportar
      </button>
      <button type='button' class='warehouse-import-btn' data-section='officers' data-section-label='oficiales' title='Importar oficiales desde JSON'>
        <i class='fas fa-file-import'></i>
        Importar
      </button>
      {{/unless}}
    </div>
  </div>
  {{/if}}

  <div class='officer-toolbar'>
    <div class='officer-search-wrapper'>
      <i class='fas fa-search'></i>
      <input type='text' class='officer-search-input' placeholder='Buscar por nombre, cargo o habilidad...' />
      <button type='button' class='officer-search-clear' title='Limpiar búsqueda' hidden>
        <i class='fas fa-times'></i>
      </button>
    </div>
    <div class='officer-view-modes' role='group' aria-label='Modo de visualización'>
      <button type='button' class='officer-view-btn' data-view-mode='grid' title='Tarjetas'>
        <i class='fas fa-th-large'></i>
      </button>
      <button type='button' class='officer-view-btn' data-view-mode='list' title='Lista compacta'>
        <i class='fas fa-list'></i>
      </button>
      <button type='button' class='officer-view-btn' data-view-mode='gallery' title='Galería'>
        <i class='fas fa-images'></i>
      </button>
    </div>
  </div>

  {{#if titles.length}}
  <div class='officer-filter-toggles'>
    <button type='button' class='officer-filter-btn active' data-filter-title='all'>
      Todos <span class='officer-filter-count'>{{officers.length}}</span>
    </button>
    {{#each titles}}
    <button type='button' class='officer-filter-btn' data-filter-title='{{this.value}}'>
      {{this.label}} <span class='officer-filter-count'>{{this.count}}</span>
    </button>
    {{/each}}
  </div>
  {{/if}}

  <div class='officers-list view-{{viewMode}}'>
    {{#each officers}}
      <div
        class='officer-card'
        data-officer-id='{{this.id}}'
        data-officer-title='{{this.title}}'
        data-search='{{this.searchText}}'
        draggable='true'
      >
        <div class='officer-avatar'>
          <img src='{{this.actorImg}}' alt='{{this.actorName}}' />
        </div>
        <div class='officer-info'>
          <div class='officer-name'>{{this.actorName}}</div>
          <div class='officer-title'>{{this.title}}</div>
          {{#if this.skill.name}}
          <div class='officer-skill-chip' title='Habilidad: {{this.skill.name}}'>
            {{#if this.skill.image}}<img src='{{this.skill.image}}' alt='' />{{else}}<i class='fas fa-star'></i>{{/if}}
            <span>{{this.skill.name}}</span>
          </div>
          {{/if}}
          <div class='officer-traits-summary'>
            <span class='pros-count'>
              <i class='fas fa-thumbs-up'></i>
              {{this.pros.length}}
              Pros
            </span>
            <span class='cons-count'>
              <i class='fas fa-thumbs-down'></i>
              {{this.cons.length}}
              Cons
            </span>
          </div>
        </div>
        <div class='officer-actions'>
          <button
            type='button'
            class='view-officer-btn'
            title='Ver detalles'
            data-officer-id='{{this.id}}'
          >
            <i class='fas fa-eye'></i>
          </button>
          {{#if ../isGM}}
          <button
            type='button'
            class='edit-officer-btn'
            title='Editar'
            data-officer-id='{{this.id}}'
          >
            <i class='fas fa-edit'></i>
          </button>
          <button
            type='button'
            class='toggle-civil-btn'
            title='{{#if ../isCivilTab}}Mover a Oficiales{{else}}Mover a Civiles{{/if}}'
            data-officer-id='{{this.id}}'
          >
            <i class='fas {{#if ../isCivilTab}}fa-user-shield{{else}}fa-user-friends{{/if}}'></i>
          </button>
          <button
            type='button'
            class='delete-officer-btn'
            title='Eliminar'
            data-officer-id='{{this.id}}'
          >
            <i class='fas fa-trash'></i>
          </button>
          {{/if}}
        </div>
      </div>
    {{else}}
      <p class='empty-state'>
        {{#if isCivilTab}}No hay civiles creados aún{{else}}No hay oficiales creados aún{{/if}}
      </p>
    {{/each}}
  </div>

  <p class='officer-no-results' hidden>
    <i class='fas fa-search'></i> No hay resultados para los filtros actuales
  </p>
</div>
