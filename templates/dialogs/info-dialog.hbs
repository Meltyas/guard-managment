<div class="custom-dialog-header">
    <div class="custom-dialog-title">
        <i class="fas fa-info-circle"></i>
        <span class="custom-dialog-title-text">Información: {{organization.name}}</span>
    </div>
    <div class="custom-dialog-controls">
        <button class="custom-dialog-btn gm-presence-toggle" title="Mostrar/ocultar presencia (Alt para invertir)">
            <i class="fas fa-eye"></i>
        </button>
        <button class="custom-dialog-btn custom-dialog-edit" title="Editar">
            <i class="fas fa-edit"></i>
        </button>
        <button class="custom-dialog-btn custom-dialog-close" title="Cerrar">
            <i class="fas fa-times"></i>
        </button>
    </div>
</div>

<div class="custom-dialog-content">
    <div class="organization-content">
        <div class="org-tabs-layout" data-current-tab="{{activeTab}}">
            <nav class="org-tabs" role="tablist" aria-orientation="vertical">
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'general')}}active{{/if}}" role="tab" data-tab="general" data-tooltip="General" data-tooltip-direction="RIGHT">
                    <i class="fas fa-info-circle"></i><span>General</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'patrols')}}active{{/if}}" role="tab" data-tab="patrols" data-tooltip="Patrullas" data-tooltip-direction="RIGHT">
                    <i class="fas fa-users"></i><span>Patrullas</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'auxiliaries')}}active{{/if}}" role="tab" data-tab="auxiliaries" data-tooltip="Auxiliares" data-tooltip-direction="RIGHT">
                    <i class="fas fa-hands-helping"></i><span>Auxiliares</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'resources')}}active{{/if}}" role="tab" data-tab="resources" data-tooltip="Recursos" data-tooltip-direction="RIGHT">
                    <i class="fas fa-coins"></i><span>Recursos</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'reputation')}}active{{/if}}" role="tab" data-tab="reputation" data-tooltip="Reputación" data-tooltip-direction="RIGHT">
                    <i class="fas fa-handshake"></i><span>Reputación</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'crimes')}}active{{/if}}" role="tab" data-tab="crimes" data-tooltip="Crímenes" data-tooltip-direction="RIGHT">
                    <i class="fas fa-gavel"></i><span>Crímenes</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'prisoners')}}active{{/if}}" role="tab" data-tab="prisoners" data-tooltip="Prisioneros" data-tooltip-direction="RIGHT">
                    <i class="fas fa-dungeon"></i><span>Prisioneros</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'gangs')}}active{{/if}}" role="tab" data-tab="gangs" data-tooltip="Bandas" data-tooltip-direction="RIGHT">
                    <i class="fas fa-skull-crossbones"></i><span>Bandas</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'buildings')}}active{{/if}}" role="tab" data-tab="buildings" data-tooltip="Edificios" data-tooltip-direction="RIGHT">
                    <i class="fas fa-building"></i><span>Edificios</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'poi')}}active{{/if}}" role="tab" data-tab="poi" data-tooltip="Gente de Interés" data-tooltip-direction="RIGHT">
                    <i class="fas fa-user-secret"></i><span>Gente de Interés</span>
                </button>
                <button type="button" class="org-tab-btn {{#if (eq activeTab 'finances')}}active{{/if}}" role="tab" data-tab="finances" data-tooltip="Finanzas" data-tooltip-direction="RIGHT">
                    <i class="fas fa-coins"></i><span>Finanzas</span>
                </button>
                <div class="active-bar" aria-hidden="true"></div>
            </nav>

            <div class="org-tab-panels">
                <section class="org-tab-panel {{#if (eq activeTab 'general')}}active{{/if}}" role="tabpanel" data-tab-panel="general">
                    {{> "modules/guard-management/templates/panels/general.hbs" organization=organization}}
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'patrols')}}active{{/if}}" role="tabpanel" data-tab-panel="patrols">
                    {{> "modules/guard-management/templates/panels/patrols.hbs" patrols=patrols}}
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'auxiliaries')}}active{{/if}}" role="tabpanel" data-tab-panel="auxiliaries">
                    {{> "modules/guard-management/templates/panels/patrols.hbs" patrols=auxiliaries}}
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'resources')}}active{{/if}}" role="tabpanel" data-tab-panel="resources">
                    {{> "modules/guard-management/templates/panels/resources.hbs" organization=organization}}
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'reputation')}}active{{/if}}" role="tabpanel" data-tab-panel="reputation">
                    {{> "modules/guard-management/templates/panels/reputation.hbs" organization=organization}}
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'crimes')}}active{{/if}}" role="tabpanel" data-tab-panel="crimes">
                    <!-- CrimesPanel renders here -->
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'prisoners')}}active{{/if}}" role="tabpanel" data-tab-panel="prisoners">
                    <!-- PrisonersPanel renders here -->
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'gangs')}}active{{/if}}" role="tabpanel" data-tab-panel="gangs">
                    <!-- GangsPanel renders here -->
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'buildings')}}active{{/if}}" role="tabpanel" data-tab-panel="buildings">
                    <!-- BuildingsPanel renders here -->
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'poi')}}active{{/if}}" role="tabpanel" data-tab-panel="poi">
                    <!-- PoiPanel renders here -->
                </section>
                <section class="org-tab-panel {{#if (eq activeTab 'finances')}}active{{/if}}" role="tabpanel" data-tab-panel="finances">
                    <!-- FinancesPanel renders here -->
                </section>
            </div>
        </div>
    </div>
</div>

<div class="custom-dialog-resize-handle"></div>
<div class="drop-overlay" style="display: none;"></div>