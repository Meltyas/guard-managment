<form class='officer-form guard-modal-form'>
  <div class='officer-content' data-dialog-id='{{dialogId}}'>
    <div class='officer-actor-section'>
      {{#if actorImg}}
        <div class='officer-actor-preview' data-drop='actor'>
          <img src='{{actorImg}}' alt='{{actorName}}' class='officer-actor-image' />
          <div class='officer-actor-name'>{{actorName}}</div>
          <button type='button' class='officer-actor-clear-btn' title='Quitar actor asignado'>
            <i class='fas fa-times'></i>
          </button>
        </div>
      {{else}}
        <div class='officer-actor-dropzone' data-drop='actor'>
          <i class='fas fa-user-plus'></i>
          <p>Arrastra un Actor aquí para asignarlo como Oficial</p>
        </div>
      {{/if}}
    </div>

    <input type='hidden' name='actorId' value='{{actorId}}' />
    <input type='hidden' name='actorName' value='{{actorName}}' />
    <input type='hidden' name='actorImg' value='{{actorImg}}' />
    <input type='hidden' name='organizationId' value='{{organizationId}}' />

    <div class='guard-modal-row'>
      <label><i class='fas fa-id-badge'></i> Título del Oficial</label>
      <input
        type='text'
        id='officer-title'
        name='title'
        value='{{title}}'
        placeholder='Ej: Capitán, Sargento, Comandante...'
        required
      />
    </div>

    <div class='guard-modal-row' style='flex-direction:row;align-items:center;'>
      <input
        type='checkbox'
        id='officer-visible'
        name='visibleToPlayers'
        {{#if visibleToPlayers}}checked{{/if}}
      />
      <label for='officer-visible' style='text-transform:none;cursor:pointer;'>Visible para jugadores</label>
    </div>

    <!-- Officer Stats Section -->
    <div class='officer-stats-section'>
      <h3>
        <i class='fas fa-chart-bar'></i>
        Estadísticas del Oficial
        <span style='font-size: 0.8rem; font-weight: normal; opacity: 0.7;'>(Modifican patrulla)</span>
      </h3>
      <div class='officer-stats-grid'>
        <div class='officer-stat-input'>
          <label>Robustismo</label>
          <input type='number' name='stat-robustismo'
                 value='{{stats.robustismo}}'
                 min='-99' max='99' />
        </div>
        <div class='officer-stat-input'>
          <label>Analítica</label>
          <input type='number' name='stat-analitica'
                 value='{{stats.analitica}}'
                 min='-99' max='99' />
        </div>
        <div class='officer-stat-input'>
          <label>Subterfugio</label>
          <input type='number' name='stat-subterfugio'
                 value='{{stats.subterfugio}}'
                 min='-99' max='99' />
        </div>
        <div class='officer-stat-input'>
          <label>Elocuencia</label>
          <input type='number' name='stat-elocuencia'
                 value='{{stats.elocuencia}}'
                 min='-99' max='99' />
        </div>
      </div>
    </div>

    <!-- Officer Skills Section (multiple) -->
    <div class='officer-skills-section'>
      <h3>
        <i class='fas fa-bolt'></i>
        Habilidades de Patrulla
        <span style='font-size: 0.8rem; font-weight: normal; opacity: 0.7;'>(Opcional)</span>
      </h3>
      <div class='skills-list' data-skills-list>
        {{#each skills}}
          <div class='skill-item' data-skill-id='{{this.id}}'>
            <div class='skill-header'>
              {{#if this.image}}
                <img src='{{this.image}}' alt='{{this.name}}' class='skill-thumb' />
              {{else}}
                <span class='skill-thumb-placeholder'><i class='fas fa-bolt'></i></span>
              {{/if}}
              <strong>{{this.name}}</strong>
              <span class='skill-hope-cost'>
                <i class='fas fa-diamond'></i>
                {{this.hopeCost}}
              </span>
              <button
                type='button'
                class='skill-edit-btn'
                data-skill-id='{{this.id}}'
                title='Editar habilidad'
              >
                <i class='fas fa-edit'></i>
              </button>
              <button
                type='button'
                class='skill-remove-btn'
                data-skill-id='{{this.id}}'
                title='Eliminar habilidad'
              >
                <i class='fas fa-times'></i>
              </button>
            </div>
          </div>
        {{else}}
          <p class='empty-skills'>No hay habilidades agregadas</p>
        {{/each}}
      </div>
      <button type='button' class='add-skill-btn'>
        <i class='fas fa-plus'></i>
        Agregar Habilidad
      </button>
    </div>

    <div class='officer-traits-section'>
      <div class='traits-column pros-column'>
        <h3>
          <i class='fas fa-thumbs-up'></i>
          Pros (Características Positivas)
        </h3>
        <div class='traits-list pros-list' data-trait-type='pro'>
          {{#each pros}}
            <div class='trait-item' data-trait-id='{{this.id}}'>
              <div class='trait-header'>
                <strong>{{this.title}}</strong>
                <button
                  type='button'
                  class='trait-edit-btn'
                  data-trait-id='{{this.id}}'
                  data-trait-type='pro'
                  title='Editar'
                >
                  <i class='fas fa-edit'></i>
                </button>
                <button
                  type='button'
                  class='trait-remove-btn'
                  data-trait-id='{{this.id}}'
                  data-trait-type='pro'
                >
                  <i class='fas fa-times'></i>
                </button>
              </div>
              <div class='trait-description'>{{{this.description}}}</div>
            </div>
          {{else}}
            <p class='empty-traits'>No hay pros agregados</p>
          {{/each}}
        </div>
        <button type='button' class='add-trait-btn' data-trait-type='pro'>
          <i class='fas fa-plus'></i>
          Agregar Pro
        </button>
      </div>

      <div class='traits-column cons-column'>
        <h3>
          <i class='fas fa-thumbs-down'></i>
          Cons (Características Negativas)
        </h3>
        <div class='traits-list cons-list' data-trait-type='con'>
          {{#each cons}}
            <div class='trait-item' data-trait-id='{{this.id}}'>
              <div class='trait-header'>
                <strong>{{this.title}}</strong>
                <button
                  type='button'
                  class='trait-edit-btn'
                  data-trait-id='{{this.id}}'
                  data-trait-type='con'
                  title='Editar'
                >
                  <i class='fas fa-edit'></i>
                </button>
                <button
                  type='button'
                  class='trait-remove-btn'
                  data-trait-id='{{this.id}}'
                  data-trait-type='con'
                >
                  <i class='fas fa-times'></i>
                </button>
              </div>
              <div class='trait-description'>{{{this.description}}}</div>
            </div>
          {{else}}
            <p class='empty-traits'>No hay cons agregados</p>
          {{/each}}
        </div>
        <button type='button' class='add-trait-btn' data-trait-type='con'>
          <i class='fas fa-plus'></i>
          Agregar Con
        </button>
      </div>
    </div>

    <!-- Form Buttons -->
    <footer class='sheet-footer flexrow'>
      <button type='submit' class='dialog-button'>
        <i class='fas fa-save'></i>
        {{#if (eq mode 'create')}}Crear{{else}}Guardar{{/if}}
      </button>
      <button type='button' class='dialog-button cancel-button'>
        <i class='fas fa-times'></i>
        Cancelar
      </button>
    </footer>
  </div>
</form>
