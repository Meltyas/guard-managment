<div class='custom-dialog-header'>
  <div class='custom-dialog-title'>
    <i class='fas fa-warehouse'></i>
    <span>GM Warehouse</span>
  </div>
  <div class='custom-dialog-controls'>
    <button class='custom-dialog-btn custom-dialog-close' type='button' aria-label='Cerrar'>
      <i class='fas fa-times'></i>
    </button>
  </div>
</div>
<div class='custom-dialog-body'>
  <div class='gm-warehouse-container'>
    <div class='warehouse-tabs'>
      <nav class='tabs' data-group='warehouse-tabs'>
        <a class='item tab active' data-tab='resources'>
          <i class='fas fa-boxes'></i>
          <span>Recursos</span>
        </a>
        <a class='item tab' data-tab='reputation'>
          <i class='fas fa-handshake'></i>
          <span>Reputación</span>
        </a>
        <a class='item tab' data-tab='patrol-effects'>
          <i class='fas fa-magic'></i>
          <span>Efectos</span>
        </a>
        <a class='item tab' data-tab='guard-modifiers'>
          <i class='fas fa-shield-alt'></i>
          <span>Modificadores</span>
        </a>
      </nav>
    </div>
    <div class='warehouse-content'>
      <section class='tab-content active' data-tab='resources'>
        <div class='content-header'>
          <h3>Plantillas de Recursos</h3>
          <div class='content-header-actions'>
            <button type='button' class='add-resource-btn'>
              <i class='fas fa-plus'></i>
              Añadir
            </button>
            <button
              type='button'
              class='warehouse-export-btn'
              data-section='resources'
              data-section-label='recursos'
              title='Exportar recursos a JSON'
            >
              <i class='fas fa-file-export'></i>
              Exportar
            </button>
            <button
              type='button'
              class='warehouse-import-btn'
              data-section='resources'
              data-section-label='recursos'
              title='Importar recursos desde JSON'
            >
              <i class='fas fa-file-import'></i>
              Importar
            </button>
          </div>
        </div>
        <div class='entity-list-search'>
          <i class='fas fa-search entity-list-search__icon'></i>
          <input type='text' class='warehouse-search-input entity-list-search__input' placeholder='Buscar recurso...' />
        </div>
        <div class='templates-list resources-list'>
          <p class='loading-state'>Loading resources...</p>
        </div>
      </section>
      <section class='tab-content' data-tab='reputation'>
        <div class='content-header'>
          <h3>Plantillas de Reputación</h3>
          <div class='content-header-actions'>
            <button type='button' class='add-reputation-btn'>
              <i class='fas fa-plus'></i>
              Añadir
            </button>
            <button
              type='button'
              class='warehouse-export-btn'
              data-section='reputations'
              data-section-label='reputaciones'
              title='Exportar reputaciones a JSON'
            >
              <i class='fas fa-file-export'></i>
              Exportar
            </button>
            <button
              type='button'
              class='warehouse-import-btn'
              data-section='reputations'
              data-section-label='reputaciones'
              title='Importar reputaciones desde JSON'
            >
              <i class='fas fa-file-import'></i>
              Importar
            </button>
          </div>
        </div>
        <div class='entity-list-search'>
          <i class='fas fa-search entity-list-search__icon'></i>
          <input type='text' class='warehouse-search-input entity-list-search__input' placeholder='Buscar reputación...' />
        </div>
        <div class='templates-list reputation-list'>
          <p class='empty-state'>Loading reputation templates...</p>
        </div>
      </section>
      <section class='tab-content' data-tab='patrol-effects'>
        <div class='content-header'>
          <h3>Plantillas de Efectos de Patrulla</h3>
          <div class='content-header-actions'>
            <button type='button' class='add-patrol-effect-btn'>
              <i class='fas fa-plus'></i>
              Añadir
            </button>
            <button
              type='button'
              class='warehouse-export-btn'
              data-section='patrolEffects'
              data-section-label='efectos-patrulla'
              title='Exportar efectos de patrulla a JSON'
            >
              <i class='fas fa-file-export'></i>
              Exportar
            </button>
            <button
              type='button'
              class='warehouse-import-btn'
              data-section='patrolEffects'
              data-section-label='efectos-patrulla'
              title='Importar efectos de patrulla desde JSON'
            >
              <i class='fas fa-file-import'></i>
              Importar
            </button>
          </div>
        </div>
        <div class='entity-list-search'>
          <i class='fas fa-search entity-list-search__icon'></i>
          <input type='text' class='warehouse-search-input entity-list-search__input' placeholder='Buscar efecto...' />
        </div>
        <div class='templates-list patrol-effects-list'>
          <p class='empty-state'>No hay efectos de patrulla creados aún</p>
        </div>
      </section>
      <section class='tab-content' data-tab='guard-modifiers'>
        <div class='content-header'>
          <h3>Plantillas de Modificadores de Guardia</h3>
          <div class='content-header-actions'>
            <button type='button' class='add-guard-modifier-btn'>
              <i class='fas fa-plus'></i>
              Añadir
            </button>
            <button
              type='button'
              class='warehouse-export-btn'
              data-section='modifiers'
              data-section-label='modificadores'
              title='Exportar modificadores a JSON'
            >
              <i class='fas fa-file-export'></i>
              Exportar
            </button>
            <button
              type='button'
              class='warehouse-import-btn'
              data-section='modifiers'
              data-section-label='modificadores'
              title='Importar modificadores desde JSON'
            >
              <i class='fas fa-file-import'></i>
              Importar
            </button>
          </div>
        </div>
        <div class='entity-list-search'>
          <i class='fas fa-search entity-list-search__icon'></i>
          <input type='text' class='warehouse-search-input entity-list-search__input' placeholder='Buscar modificador...' />
        </div>
        <div class='templates-list guard-modifiers-list'>
          <p class='empty-state'>No hay modificadores creados aún</p>
        </div>
      </section>
    </div>
  </div>
</div>