<form class="guard-modal-form">

  <div class="guard-modal-row order-resource-header">
    <span class="order-resource-name">
      <i class="fas fa-box-open"></i>
      {{resourceName}}
    </span>
  </div>

  <div class="guard-modal-row">
    <label><i class="fas fa-shopping-cart"></i> Tipo de encargo</label>
    <div class="guard-modal-toggle-group">
      <label class="guard-modal-toggle-option">
        <input type="radio" name="orderType" value="comprar" checked />
        <span><i class="fas fa-coins"></i> Comprar</span>
      </label>
      <label class="guard-modal-toggle-option">
        <input type="radio" name="orderType" value="craftear" />
        <span><i class="fas fa-hammer"></i> Craftear</span>
      </label>
    </div>
  </div>

  <div class="guard-modal-split">
    <div class="guard-modal-row">
      <label><i class="fas fa-cubes"></i> Cantidad</label>
      <input type="number" name="quantity" value="1" min="1" max="9999" required />
    </div>
    <div class="guard-modal-row">
      <label><i class="fas fa-coins"></i> Coste total (presupuesto)</label>
      <input type="number" name="totalCost" value="0" min="0" step="1" required />
    </div>
  </div>

  <div class="guard-modal-row">
    <label><i class="fas fa-hourglass-half"></i> Fases hasta llegar</label>
    <input type="number" name="phasesUntilArrival" value="0" min="0" max="999" required />
    <p class="guard-modal-hint"><i class="fas fa-info-circle"></i> 0 = llega inmediatamente al confirmar el encargo.</p>
  </div>

  <div class="guard-modal-row order-resource-visibility">
    <label class="guard-modal-checkbox-label">
      <input type="checkbox" name="showArrivalToPlayers" value="1" checked />
      <span><i class="fas fa-eye"></i> Mostrar llegada a jugadores</span>
    </label>
    <p class="guard-modal-hint"><i class="fas fa-info-circle"></i> Si está desmarcado, solo el GM verá cuándo llega el encargo.</p>
  </div>

  <input type="hidden" name="resourceId" value="{{resourceId}}" />
  <input type="hidden" name="currentTurn" value="{{currentTurn}}" />

</form>
