<div class="organization-info">
  <div class="info-section prisoners-section">
    <h3>
      <i class="fas fa-dungeon"></i> Celdas Temporales
      <button type="button" class="prisoner-config-btn btn-icon" title="Configurar celdas"
        style="margin-left: auto;">
        <i class="fas fa-cog"></i>
      </button>
    </h3>

    {{!-- Cells Grid (2 per row) --}}
    <div class="prison-cells-grid" data-cell-count="{{cellCount}}">
      {{#each cells}}
        <div class="prison-cell {{#if this.prisoners.length}}occupied{{else}}empty{{/if}} {{#if this.isOvercrowded}}cell-overcrowded{{/if}}"
             data-cell-index="{{this.index}}"
             data-drop="prisoner">
          <div class="cell-header">
            <span class="cell-number">Celda {{this.displayIndex}}</span>
            {{#if this.prisoners.length}}
              <span class="cell-capacity-badge {{#if this.isOvercrowded}}overcrowded{{/if}}">
                {{this.prisoners.length}}/{{this.capacity}}
              </span>
            {{/if}}
            {{#if this.isOvercrowded}}
              <span class="cell-status cell-status-overcrowded">
                <i class="fas fa-exclamation-triangle"></i> Hacinada
              </span>
            {{/if}}
          </div>

          {{#if this.prisoners.length}}
            {{#each this.prisoners}}
              <div class="prisoner-cell-summary" data-prisoner-id="{{this.id}}">
                <div class="cell-prisoner-info">
                  {{#if this.img}}
                    <div class="prisoner-image">
                      <img src="{{this.img}}" alt="{{this.name}}"
                           onerror="this.style.display='none'" />
                    </div>
                  {{/if}}
                  <span class="prisoner-name">{{this.name}}</span>
                  <span class="cell-status cell-status-{{this.status}}">
                    {{this.statusLabel}}
                  </span>
                </div>
                {{#if this.hasSentence}}
                  <div class="cell-sentence-info {{#if (eq this.remainingPhases 0)}}sentence-expired{{/if}}">
                    <i class="fas fa-hourglass-half"></i>
                    <span>Entrada: fase {{this.sentenceStartPhase}}</span>
                    <span class="sentence-separator">|</span>
                    <span>Sentencia: {{this.sentencePhases}} fases</span>
                    <span class="sentence-separator">|</span>
                    <span>Restantes: <strong>{{this.remainingPhases}}</strong></span>
                  </div>
                {{/if}}
                {{#if this.notes}}
                  <div class="cell-prisoner-notes">{{{this.notes}}}</div>
                {{/if}}
                {{#if this.crimeNames.length}}
                  <div class="prisoner-crime-badges">
                    {{#each this.crimeNames}}
                      <span class="prisoner-crime-badge offense-{{this.offenseType}}">{{this.name}}</span>
                    {{/each}}
                  </div>
                {{/if}}
                <div class="prisoner-cell-actions">
                  <button type="button" class="cell-action-btn prisoner-crimes-btn" title="Gestionar crímenes"
                    data-prisoner-id="{{this.id}}">
                    <i class="fas fa-gavel"></i>
                  </button>
                  <button type="button" class="cell-action-btn prisoner-edit-btn" title="Editar notas y turno"
                    data-prisoner-id="{{this.id}}">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="cell-action-btn prisoner-release-btn" title="Liberar al prisionero"
                    data-prisoner-id="{{this.id}}" data-prisoner-name="{{this.name}}">
                    <i class="fas fa-door-open"></i>
                  </button>
                  <button type="button" class="cell-action-btn prisoner-forced-labor-btn" title="Enviar a trabajos forzados"
                    data-prisoner-id="{{this.id}}" data-prisoner-name="{{this.name}}">
                    <i class="fas fa-hammer"></i>
                  </button>
                  <button type="button" class="cell-action-btn prisoner-prison-btn" title="Transferir a prisión permanente"
                    data-prisoner-id="{{this.id}}" data-prisoner-name="{{this.name}}">
                    <i class="fas fa-lock"></i>
                  </button>
                  <button type="button" class="cell-action-btn prisoner-execute-btn" title="Enviar al corredor de la muerte"
                    data-prisoner-id="{{this.id}}" data-prisoner-name="{{this.name}}">
                    <i class="fas fa-skull-crossbones"></i>
                  </button>
                </div>
              </div>
            {{/each}}
          {{else}}
            <div class="cell-empty-state">
              <i class="fas fa-user-plus"></i>
              <span>Arrastra un actor aquí</span>
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>

    {{!-- Prisoner Records (fichas) below the grid --}}
    {{#if records.length}}
      <div class="prisoner-records-section">
        <h4><i class="fas fa-folder-open"></i> Fichas de Prisioneros</h4>

        {{!-- Search and Filter Bar --}}
        <div class="prisoner-records-toolbar">
          <div class="prisoner-search-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" class="prisoner-search-input" placeholder="Buscar por nombre..." />
          </div>
          <div class="prisoner-filters">
            <button type="button" class="prisoner-filter-btn" data-filter-status="imprisoned" title="Presos">
              <i class="fas fa-lock"></i> Preso
            </button>
            <button type="button" class="prisoner-filter-btn" data-filter-status="death_row" title="Corredor de la muerte">
              <i class="fas fa-skull-crossbones"></i> Corredor
            </button>
            <button type="button" class="prisoner-filter-btn" data-filter-status="executed" title="Ejecutados">
              <i class="fas fa-skull"></i> Ejecutado
            </button>
            <button type="button" class="prisoner-filter-btn" data-filter-status="released" title="Liberados">
              <i class="fas fa-door-open"></i> Liberado
            </button>
            <button type="button" class="prisoner-filter-btn" data-filter-status="forced_labor" title="Trabajos forzados">
              <i class="fas fa-hammer"></i> T. Forzados
            </button>
            <button type="button" class="prisoner-filter-btn" data-filter-status="transferred_to_prison" title="En prisión permanente">
              <i class="fas fa-dungeon"></i> Prisión
            </button>
          </div>
        </div>

        {{#each records}}
          <div class="prisoner-record" data-prisoner-id="{{this.id}}" data-prisoner-status="{{this.status}}">
            <div class="record-header">
              {{#if this.img}}
                <div class="record-image">
                  <img src="{{this.img}}" alt="{{this.name}}"
                       onerror="this.style.display='none'" />
                </div>
              {{/if}}
              <div class="record-title">
                <span class="record-name">{{this.name}}</span>
                <span class="record-status record-status-{{this.status}}">{{this.statusLabel}}</span>
              </div>
              <div class="record-actions">
                <button type="button" class="record-chat-btn" title="Enviar al chat"
                  data-prisoner-id="{{this.id}}">
                  <i class="fas fa-comment-dots"></i>
                </button>
                {{#if this.canReturn}}
                  <button type="button" class="record-return-btn" title="Devolver a la celda"
                    data-prisoner-id="{{this.id}}" data-prisoner-name="{{this.name}}">
                    <i class="fas fa-undo"></i> Devolver a celda
                  </button>
                {{/if}}
                {{#if this.canExecute}}
                  <button type="button" class="record-execute-btn" title="Ejecutar"
                    data-prisoner-id="{{this.id}}" data-prisoner-name="{{this.name}}">
                    <i class="fas fa-skull-crossbones"></i> Ejecutar
                  </button>
                {{/if}}
              </div>
            </div>
            {{#if this.hasSentence}}
              <div class="record-sentence-info {{#if (eq this.remainingPhases 0)}}sentence-expired{{/if}}">
                <i class="fas fa-hourglass-half"></i>
                <span>Entrada: fase {{this.sentenceStartPhase}}</span>
                <span class="sentence-separator">|</span>
                <span>Sentencia: {{this.sentencePhases}} fases</span>
                <span class="sentence-separator">|</span>
                <span>Restantes: <strong>{{this.remainingPhases}}</strong></span>
              </div>
            {{/if}}
            {{#if this.notes}}
              <div class="record-notes">{{{this.notes}}}</div>
            {{/if}}
            {{#if this.crimeNames.length}}
              <div class="record-crimes">
                <i class="fas fa-gavel"></i>
                {{#each this.crimeNames}}
                  <span class="prisoner-crime-badge offense-{{this.offenseType}}">{{this.name}}</span>
                {{/each}}
              </div>
            {{/if}}
            <div class="record-history">
              {{#each this.history}}
                <div class="record-entry record-entry-{{this.action}}"
                     data-entry-timestamp="{{this.timestamp}}"
                     title="{{this.performedBy}} — {{this.timeAgo}}">
                  <span class="record-entry-text">{{this.details}}</span>
                </div>
              {{/each}}
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}
  </div>
</div>
