<div class='organization-info'>
  <div class='info-section'>
    <h3><i class='fas fa-shield-alt'></i> Información General</h3>
    <div class='info-grid'>
      <div class='info-item'>
        <label>Nombre:</label>
        <span>{{organization.name}}</span>
      </div>
      <div class='info-item'>
        <label>Subtítulo:</label>
        <span>{{#if organization.subtitle}}{{organization.subtitle}}{{else}}Sin subtítulo{{/if}}</span>
      </div>
    </div>
  </div>

  <div class='info-section'>
    <h3><i class='fas fa-chart-bar'></i> Estadísticas</h3>
    <div class='stats-effects-cols'>
      <div class='stats-display'>
        {{#each statsDisplay}}
          <button
            type='button'
            class='stat-chip {{this.cssClass}} clickable-stat'
            data-stat='{{this.key}}'
            data-tooltip='{{patrolStatTooltip this.orgStatData this.key}}'
            title='{{this.label}}'
          >
            <div class='stat-chip__img' style='background-image: url("{{this.img}}");'></div>
            <div class='stat-chip__nums'>
              <span class='stat-chip__base'>{{this.base}}</span>
              <span class='stat-chip__total'>({{this.total}})</span>
            </div>
          </button>
        {{/each}}
      </div>
      <div class='modifiers-grid compact'>
        {{#if activeModifiers.length}}
          {{#each activeModifiers}}
            <div
              class='modifier-compact {{this.borderClass}}'
              data-id='{{this.id}}'
              data-tooltip='{{this.tooltip}}'
            >
              <img src='{{this.img}}' alt='{{this.name}}' class='modifier-icon-large' />
            </div>
          {{/each}}
        {{else}}
          <span class='effects-empty'>Sin modificadores</span>
        {{/if}}
      </div>
    </div>
  </div>

  <div class='info-section'>
    <h3><i class='fas fa-users'></i> Patrullas</h3>
    <div class='patrol-count'>
      <span class='count'>{{organization.patrols.length}}</span>
      <span class='label'>patrullas activas</span>
    </div>
  </div>

  {{#if officerSkills.length}}
    <div class='info-section'>
      <h3><i class='fas fa-bolt'></i> Habilidades Disponibles</h3>
      <div class='officer-skills-list'>
        {{#each officerSkills}}
          <div class='officer-skill-entry'>
            <div class='skill-info'>
              {{#if this.skillImage}}
                <img src='{{this.skillImage}}' alt='{{this.skillName}}' class='skill-icon' />
              {{/if}}
              <span class='skill-name'>{{this.skillName}}</span>
            </div>
            <div class='skill-officer'>
              {{#if this.officerImg}}
                <img
                  src='{{this.officerImg}}'
                  alt='{{this.officerName}}'
                  class='officer-mini-avatar'
                />
              {{/if}}
              <span class='officer-info-text'>{{this.officerName}} — {{this.patrolName}}</span>
            </div>
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}
</div>