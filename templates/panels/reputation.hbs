<div class="organization-info">
  <div class="info-section reputation-section">
    <h3><i class="fas fa-handshake"></i> Reputación</h3>
    <div class="reputation-list reputation-list--grid" data-organization-id="{{organizationId}}">
      {{#if reputation.length}}
        {{#each reputation}}
          <div class="dh-card dh-card--reputation{{#unless this.image}} dh-card--no-image{{/unless}}" data-reputation-id="{{this.id}}">
            <div class="dh-card-inner">
              <div class="dh-card-header">
                {{#if this.image}}
                <div class="dh-card-header-image">
                  <img alt="{{this.name}}" src="{{this.image}}" />
                </div>
                <img class="dh-card-divider" src="modules/guard-management/assets/card/card-type-middle-deco.png" />
                {{/if}}
                <div class="dh-card-type">reputación</div>
                <div class="dh-card-quantity-badge dh-card-quantity-badge--level-{{this.level}}">{{this.value}}</div>
              </div>
              <div class="dh-card-body">
                <div class="dh-card-title-block">
                  <div class="dh-card-title-wrapper">
                    <h1 class="dh-card-title">{{this.name}}</h1>
                  </div>
                  {{#if this.description}}
                  <div class="dh-card-subtitle">
                    <p>{{this.description}}</p>
                  </div>
                  {{/if}}
                </div>
              </div>
            </div>
            <div class="dh-card-actions dh-card-actions--list">
              <button type="button" class="dh-card-action-btn send-to-chat-btn" title="Enviar al chat"
                data-reputation-id="{{this.id}}" data-reputation-name="{{this.name}}"
                data-organization-id="{{../organizationId}}">
                <i class="fas fa-comment"></i>
              </button>
              <button type="button" class="dh-card-action-btn edit-reputation-btn" title="Editar reputación"
                data-reputation-id="{{this.id}}">
                <i class="fas fa-edit"></i>
              </button>
              <button type="button" class="dh-card-action-btn dh-card-action-btn--danger remove-reputation-btn" title="Remover reputación"
                data-reputation-id="{{this.id}}" data-reputation-name="{{this.name}}">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="empty-state">
          No hay reputación registrada.<br /><small>Arrastra reputaciones desde el warehouse o crea una nueva.</small>
        </p>
      {{/if}}
    </div>
  </div>
</div>
