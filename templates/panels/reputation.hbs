<div class="organization-info">
  <div class="info-section reputation-section">
    <h3><i class="fas fa-handshake"></i> Reputación</h3>
    <div class="entity-list" data-organization-id="{{organizationId}}">
      {{#if reputation.length}}
        {{#each reputation}}
          <div class="entity-row" data-entity-id="{{this.id}}">
            <!-- Collapsed row -->
            <div class="entity-row__summary">
              <button type="button" class="entity-row__toggle" aria-expanded="false" aria-label="Expandir">
                <img class="entity-row__thumb" src="{{#if this.image}}{{this.image}}{{else}}icons/environment/people/group.webp{{/if}}" alt="{{this.name}}" />
              </button>
              <span class="entity-row__badge entity-row__badge--level-{{this.level}}">{{this.value}}</span>
              <span class="entity-row__name">{{this.name}}</span>
              <div class="entity-row__actions">
                <button type="button" class="entity-row__btn send-to-chat-btn" title="Enviar al chat"
                  data-reputation-id="{{this.id}}" data-reputation-name="{{this.name}}"
                  data-organization-id="{{../organizationId}}">
                  <i class="fas fa-comment"></i>
                </button>
                <button type="button" class="entity-row__btn edit-reputation-btn" title="Editar"
                  data-reputation-id="{{this.id}}">
                  <i class="fas fa-edit"></i>
                </button>
                <button type="button" class="entity-row__btn entity-row__btn--danger remove-reputation-btn" title="Remover"
                  data-reputation-id="{{this.id}}" data-reputation-name="{{this.name}}">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
            <!-- Expanded detail -->
            <div class="entity-row__detail" hidden>
              <div class="entity-row__detail-image">
                <img class="entity-row__detail-img" src="{{#if this.image}}{{this.image}}{{else}}icons/environment/people/group.webp{{/if}}" alt="{{this.name}}" />
              </div>
              <div class="entity-row__detail-body">
                <div class="entity-row__detail-title">{{this.name}}</div>
                <div class="entity-row__detail-badge entity-row__detail-badge--level-{{this.level}}">{{this.value}}</div>
                {{#if this.faction}}
                  <div class="entity-row__detail-meta"><i class="fas fa-users"></i> {{this.faction}}</div>
                {{/if}}
                {{#if this.description}}
                  <p class="entity-row__detail-desc">{{this.description}}</p>
                {{/if}}
              </div>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="empty-state">
          No hay reputación registrada.<br /><small>Arrastra reputaciones desde el warehouse o crea una nueva.</small>
        </p>
      {{/if}}
    </div>
  </div>
</div>
