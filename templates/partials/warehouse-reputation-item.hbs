<div class="dh-card dh-card--reputation{{#unless image}} dh-card--no-image{{/unless}}" data-reputation-id="{{id}}" draggable="true" title="Arrastra esta reputación a una organización para asignarla">
  <div class="dh-card-inner">
    <div class="dh-card-header">
      {{#if image}}
      <div class="dh-card-header-image">
        <img alt="{{name}}" src="{{image}}" />
      </div>
      <img class="dh-card-divider" src="modules/guard-management/assets/card/card-type-middle-deco.png" />
      {{/if}}
      <div class="dh-card-type">reputación</div>
      <div class="dh-card-quantity-badge dh-card-quantity-badge--level-{{level}}">{{levelLabel}}</div>
    </div>
    <div class="dh-card-body">
      <div class="dh-card-title-block">
        <div class="dh-card-title-wrapper">
          <h1 class="dh-card-title">{{name}}</h1>
        </div>
        {{#if description}}
        <div class="dh-card-subtitle">
          <p>{{description}}</p>
        </div>
        {{/if}}
      </div>
    </div>
  </div>
  <div class="dh-card-actions dh-card-actions--list">
    <button type="button" class="dh-card-action-btn send-to-chat-template-btn" title="Enviar al chat" data-reputation-id="{{id}}">
      <i class="fas fa-comment"></i>
    </button>
    <button type="button" class="dh-card-action-btn edit-template-btn" title="Editar template">
      <i class="fas fa-edit"></i>
    </button>
    <button type="button" class="dh-card-action-btn duplicate-template-btn" title="Duplicar template">
      <i class="fas fa-copy"></i>
    </button>
    <button type="button" class="dh-card-action-btn dh-card-action-btn--danger delete-template-btn" title="Eliminar template">
      <i class="fas fa-trash"></i>
    </button>
  </div>
</div>
