<div class="entity-row resource-template" data-resource-id="{{id}}" draggable="true" title="Arrastra este recurso a una organización para asignarlo">
  <div class="entity-row__summary">
    <button type="button" class="entity-row__toggle" aria-expanded="false" aria-label="Expandir">
      <img class="entity-row__thumb" src="{{#if image}}{{image}}{{else}}icons/commodities/metal/ingot-stack-silver.webp{{/if}}" alt="{{name}}" />
    </button>
    <span class="entity-row__qty">×{{quantity}}</span>
    <span class="entity-row__name">{{name}}</span>
    <div class="entity-row__actions">
      <button type="button" class="entity-row__btn send-to-chat-template-btn" title="Enviar al chat" data-resource-id="{{id}}">
        <i class="fas fa-comment"></i>
      </button>
      <button type="button" class="entity-row__btn edit-template-btn" title="Editar">
        <i class="fas fa-edit"></i>
      </button>
      <button type="button" class="entity-row__btn duplicate-template-btn" title="Duplicar">
        <i class="fas fa-copy"></i>
      </button>
      <button type="button" class="entity-row__btn entity-row__btn--danger delete-template-btn" title="Eliminar">
        <i class="fas fa-trash"></i>
      </button>
    </div>
  </div>
  <div class="entity-row__detail" hidden>
    <div class="entity-row__detail-image">
      <img class="entity-row__detail-img" src="{{#if image}}{{image}}{{else}}icons/commodities/metal/ingot-stack-silver.webp{{/if}}" alt="{{name}}" />
    </div>
    <div class="entity-row__detail-body">
      <div class="entity-row__detail-title">{{name}}</div>
      <div class="entity-row__detail-badge">×{{quantity}} unidades</div>
      {{#if description}}
        <p class="entity-row__detail-desc">{{description}}</p>
      {{/if}}
    </div>
  </div>
</div>
